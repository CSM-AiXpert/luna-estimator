# =============================================================================
# Luna Drywall & Paint — Environment Variables
# =============================================================================
# Copy this file to the root of your Next.js project as .env.local
# and fill in the values.
#
# IMPORTANT: Never commit .env.local to version control!
# =============================================================================

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Supabase Dashboard → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Found in: Supabase Dashboard → Settings → API → service_role key
# WARNING: This key has full database access. Never expose it to the browser!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─────────────────────────────────────────────
# AI Providers
# ─────────────────────────────────────────────
# OpenAI API key (for GPT-4o, DALL-E, etc.)
OPENAI_API_KEY=sk-...

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# ─────────────────────────────────────────────
# GoHighLevel (GHL) Integration
# ─────────────────────────────────────────────
# Private Integration token from GHL Settings → Integrations → Private Integrations
GHL_PRIVATE_INTEGRATION_TOKEN=your-ghl-private-integration-token

# Your GHL Location ID (found in Settings → Business Info)
GHL_LOCATION_ID=your-ghl-location-id

# GHL Pipeline ID for opportunities (found in Opportunities → Pipelines)
GHL_PIPELINE_ID=your-ghl-pipeline-id

# Webhook secret for verifying inbound GHL webhooks
# (set in GHL Settings → Webhooks)
GHL_WEBHOOK_SECRET=your-ghl-webhook-secret

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://lunadrywallandpaint.com

# Optional: Set to "development" for local dev
# NODE_ENV=development
